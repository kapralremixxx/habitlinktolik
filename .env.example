# -------------------------------------------------
# General
# -------------------------------------------------
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# -------------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=habitlink
POSTGRES_PASSWORD=habitlink_pass
POSTGRES_DB=habitlink

# -------------------------------------------------
# JWT
# -------------------------------------------------
JWT_SECRET=super-secret-jwt-key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# -------------------------------------------------
# OAuth / Social Login
# -------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
APPLE_CLIENT_ID=your-apple-service-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# -------------------------------------------------
# Firebase Cloud Messaging (Push)
# -------------------------------------------------
FCM_SERVER_KEY=your-fcm-server-key
FCM_SENDER_ID=your-fcm-sender-id

# -------------------------------------------------
# Stripe (Payments)
# -------------------------------------------------
STRIPE_SECRET_KEY=sk_test_****************
STRIPE_WEBHOOK_SECRET=whsec_****************

# -------------------------------------------------
# OpenAI (AI Habit Coach)
# -------------------------------------------------
OPENAI_API_KEY=your-openai-api-key

# -------------------------------------------------
# Google Play Billing (Android)
# -------------------------------------------------
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# -------------------------------------------------
# Apple In-App Purchases (iOS)
# -------------------------------------------------
APPLE_IAP_SHARED_SECRET=your-apple-iap-secret
